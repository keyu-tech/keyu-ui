{
  "name": "@keyu-tech/keyu-ui",
  "version": "0.0.0-semantic-release",
  "description": "Component library for the Circuit direction of the Keyu design system.",
  "license": "MIT",
  "homepage": "https://keyu-tech.github.io/keyu-ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyu-tech/keyu-ui.git"
  },
  "bugs": "https://github.com/keyu-tech/keyu-ui/issues",
  "keywords": ["shadcn", "design-system", "react", "ui", "keyu", "circuit"],
  "sideEffects": ["**/*.css"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./tokens.css",
    "./base.css": "./base.css",
    "./shadcn.css": "./shadcn.css",
    "./registry.json": "./registry.json"
  },
  "files": [
    "dist",
    "tokens.css",
    "base.css",
    "shadcn.css",
    "registry.json",
    "r",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "registry": "node scripts/build-registry.mjs",
    "prepublishOnly": "tsc --noEmit && tsup && node scripts/build-registry.mjs"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
